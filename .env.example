# API
PORT=4000
APP_BASE_URL=http://localhost:4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/callcrm?schema=public

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SECRET=your_twilio_api_key_secret_here
TWILIO_PHONE_NUMBER=+441234567890
ROUTE_SALES_NUMBER=+441111111111
ROUTE_SUPPORT_NUMBER=+442222222222
ROUTE_ACCOUNTS_NUMBER=+443333333333
DEFAULT_ROUTE_DIGIT=2
AFTER_HOURS_ROUTE_NUMBER=
BUSINESS_HOURS_START=9
BUSINESS_HOURS_END=18
BUSINESS_DAYS=1,2,3,4,5
BUSINESS_HOLIDAYS=
LUNCH_BREAK_START=13
LUNCH_BREAK_END=14
ENABLE_FAILOVER=true
MISSED_CALL_ALERT_EMAIL=alerts@yourcompany.com

# OpenAI (Phase 2, optional)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
