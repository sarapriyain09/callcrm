generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CallDirection {
  INBOUND
  OUTBOUND
}

enum CallOutcome {
  ANSWERED
  MISSED
  VOICEMAIL
  ABANDONED
}

enum UserRole {
  ADMIN
  AGENT
}

enum UserTeam {
  SALES
  SUPPORT
  ACCOUNTS
}

enum AgentActionStatus {
  PENDING
  APPROVED
  EXECUTED
  REJECTED
  FAILED
}

enum AgentActionPriority {
  LOW
  MEDIUM
  HIGH
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String   @unique
  passwordHash String
  role         UserRole @default(AGENT)
  team         UserTeam @default(SUPPORT)
  phoneNumber  String?  @unique
  isActive     Boolean  @default(true)
  isAvailable  Boolean  @default(false)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Contact {
  id          String   @id @default(cuid())
  name        String?
  phone       String   @unique
  email       String?
  tags        String[]
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  callLogs    CallLog[]
}

model CallLog {
  id                  String        @id @default(cuid())
  twilioCallSid       String        @unique
  direction           CallDirection @default(INBOUND)
  fromNumber          String
  toNumber            String
  ivrSelection        String?
  routedTo            String?
  status              String
  durationSeconds     Int?
  outcome             CallOutcome?
  recordingSid        String?
  recordingUrl        String?
  recordingStatus     String?
  transcript          String?
  summary             String?
  summaryModel        String?
  summaryGeneratedAt  DateTime?
  actionItems         String[]
  contactId           String?
  contact             Contact?      @relation(fields: [contactId], references: [id])
  agentActions        AgentAction[]
  agentName           String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([fromNumber])
  @@index([status])
  @@index([createdAt])
}

model AgentAction {
  id          String              @id @default(cuid())
  callId       String
  call         CallLog            @relation(fields: [callId], references: [id], onDelete: Cascade)
  actionType   String
  title        String
  details      String?
  reasoning    String?
  payload      Json?
  priority     AgentActionPriority @default(MEDIUM)
  status       AgentActionStatus   @default(PENDING)
  executionAttempts Int            @default(0)
  lastError    String?
  nextRetryAt  DateTime?
  executedAt   DateTime?
  failedAt     DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([callId])
  @@index([status])
  @@index([priority])
  @@index([nextRetryAt])
}
