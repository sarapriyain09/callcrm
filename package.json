{
  "name": "callcrm",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:api dev:web",
    "dev:api": "npm run dev --workspace @callcrm/api",
    "dev:web": "npm run dev --workspace @callcrm/web",
    "build": "npm-run-all build:api build:web",
    "build:api": "npm run build --workspace @callcrm/api",
    "build:web": "npm run build --workspace @callcrm/web",
    "prisma:generate": "npm run prisma:generate --workspace @callcrm/api",
    "prisma:migrate": "npm run prisma:migrate --workspace @callcrm/api",
    "seed": "npm run seed --workspace @callcrm/api"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
